# Database Configuration
DB_HOST=pgbouncer
DB_PORT=6432
DB_NAME=cafe
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration — MUST be changed for production!
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Server Configuration
PORT=8088
NODE_ENV=production

# CORS — comma-separated list of allowed origins (required for production)
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Superadmin Configuration — MUST be changed for production!
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
SUPERADMIN_NAME=Super Administrator
