# Frontend Environment Variables — copy to .env.production (gitignored) for production
# Vite env files loaded per mode:
#   .env.development  → npm run dev          (local, tracked)
#   .env.production   → npm run build        (gitignored, create locally)
#   .env.local        → all modes, overrides (gitignored)

# Backend API base URL (must include /api suffix)
VITE_API_URL=http://localhost:8088/api

# App metadata
VITE_APP_NAME=Mario Juicy
VITE_APP_VERSION=1.0.0

# --- Production values (for .env.production) ---
# VITE_API_URL=https://mario-v2-backend.ntoric.com/api
