{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mario Juicy",
  "version": "1.0.0",
  "identifier": "com.mario.juicy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "env": {
      "VITE_API_URL": "https://mario-v2-backend.ntoric.com/api"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Mario Juicy",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/logo.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  }
}
